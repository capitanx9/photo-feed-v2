# syntax=docker/dockerfile:1.7

# Dev image for the Next.js web app. Runs `next dev` with source mounted
# from the host — hot reload on edit. node_modules stays inside the
# container (declared as a volume in docker-compose.dev.yml) so host
# npm installs don't collide with the container's Linux binaries.

FROM node:22-alpine

WORKDIR /app/packages/web

# Only lockfiles at image build. Layer stays cached across code edits.
COPY packages/web/package.json packages/web/package-lock.json ./
RUN npm ci

ENV NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME=0.0.0.0 \
    PORT=3000

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
